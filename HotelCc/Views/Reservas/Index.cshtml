@model IEnumerable<HotelCc.Models.Reserva>

@{
    ViewData["Title"] = "Reservas";
}

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">

    <h2 class="mb-0">📋 Gestión de Reservas</h2>

    <!-- BOTÓN NUEVA RESERVA -->
    <a asp-controller="Habitaciones"
       asp-action="Index"
       class="btn btn-success">
        ➕ Nueva Reserva
    </a>

</div>

<!-- TABLA -->
<div class="table-responsive">
    <table class="table table-hover table-bordered align-middle shadow-sm">

        <thead class="table-dark">
            <tr>
                <th>Habitación</th>
                <th>Usuario / Huésped</th>
                <th>Entrada</th>
                <th>Salida</th>
                <th>Fecha Reserva</th>
                <th>Total</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <!-- HABITACIÓN -->
                    <td class="fw-bold text-primary">
                        🏨 @item.Habitacion?.Numero
                    </td>

                    <!-- USUARIO O EXTERNO -->
                    <td>
                        @if (item.Usuario != null)
                        {
                            <span>👤 @item.Usuario.Nombre</span>
                        }
                        else
                        {
                            <span class="text-muted">
                                🧳 @item.NombreHuespedExterno
                            </span>
                        }
                    </td>

                    <!-- FECHA ENTRADA -->
                    <td>
                        📅 @item.FechaEntrada.ToString("dd/MM/yyyy")
                    </td>

                    <!-- FECHA SALIDA -->
                    <td>
                        📅 @item.FechaSalida.ToString("dd/MM/yyyy")
                    </td>

                    <!-- FECHA RESERVA -->
                    <td>
                        🕒 @item.FechaReserva.ToString("dd/MM/yyyy HH:mm")
                    </td>

                    <!-- TOTAL -->
                    <td class="fw-bold text-success">
                        S/ @item.Total.ToString("0.00")
                    </td>

                    <!-- ACCIONES -->
                    <td>

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-info">
                            Ver
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-danger">
                            Eliminar
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>
</div>