@model HotelCc.Models.Reserva

@{
    ViewData["Title"] = "Detalle Reserva";
}

<div class="container">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card border-0 shadow rounded-4">

                <div class="card-header bg-primary text-white rounded-top-4">

                    <h3 class="mb-0">
                        📅 Detalle de Reserva
                    </h3>

                </div>

                <div class="card-body p-4">

                    <div class="row mb-3">

                        <div class="col-md-6">
                            <label class="text-muted">
                                Usuario
                            </label>

                            <h5>
                                @Model.Usuario?.Nombre
                            </h5>
                        </div>

                        <div class="col-md-6">
                            <label class="text-muted">
                                Habitación
                            </label>

                            <h5>
                                🛏 @Model.Habitacion?.Numero
                            </h5>
                        </div>

                    </div>

                    <div class="row mb-3">

                        <div class="col-md-6">
                            <label class="text-muted">
                                Fecha Entrada
                            </label>

                            <h5>
                                @Model.FechaEntrada.ToString("dd/MM/yyyy")
                            </h5>
                        </div>

                        <div class="col-md-6">
                            <label class="text-muted">
                                Fecha Salida
                            </label>

                            <h5>
                                @Model.FechaSalida.ToString("dd/MM/yyyy")
                            </h5>
                        </div>

                    </div>

                    <div class="row mb-4">

                        <div class="col-md-6">
                            <label class="text-muted">
                                Fecha Reserva
                            </label>

                            <h5>
                                @Model.FechaReserva.ToString("dd/MM/yyyy")
                            </h5>
                        </div>

                        <div class="col-md-6">

                            <label class="text-muted">
                                Estado
                            </label>

                            <div>

                                @if (Model.FechaSalida >= DateTime.Today)
                                {
                                    <span class="badge bg-danger fs-6">
                                        Ocupada
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success fs-6">
                                        Finalizada
                                    </span>
                                }

                            </div>

                        </div>

                    </div>

                    <div class="d-flex gap-2">

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            ← Volver
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>