@model HotelCc.Models.Reserva

@{
    ViewData["Title"] = "Nueva Reserva";
}

<h2 class="mb-4">➕ Nueva Reserva (Modo Admin)</h2>

<form asp-action="Create" method="post">

    <!-- =========================
         TIPO DE CLIENTE
         ========================= -->
    <div class="mb-3">
        <label class="form-label fw-bold">¿Para quién es la reserva?</label>

        <div class="form-check">
            <input class="form-check-input"
                   type="radio"
                   name="tipoCliente"
                   value="usuario"
                   checked />

            <label class="form-check-label">
                👤 Usuario registrado
            </label>
        </div>

        <div class="form-check">
            <input class="form-check-input"
                   type="radio"
                   name="tipoCliente"
                   value="externo" />

            <label class="form-check-label">
                🧍 Huésped externo
            </label>
        </div>
    </div>

    <hr />

    <!-- =========================
         USUARIO REGISTRADO
         ========================= -->
    <div class="mb-3" id="usuarioBox">
        <label class="form-label">Seleccionar usuario</label>

        <select asp-for="UsuarioId"
                class="form-control"
                asp-items="ViewBag.UsuarioId">
            <option value="">-- Seleccione un usuario --</option>
        </select>

        <small class="text-muted">
            Solo si la reserva es para un usuario registrado.
        </small>
    </div>

    <!-- =========================
         HUÉSPED EXTERNO
         ========================= -->
    <div class="mb-3" id="externoBox" style="display:none;">
        <label class="form-label">Nombre del huésped externo</label>

        <input asp-for="NombreHuespedExterno"
               class="form-control"
               placeholder="Ej: Juan Pérez" />

        <small class="text-muted">
            Solo si el cliente no está registrado en el sistema.
        </small>
    </div>

    <hr />

    <!-- =========================
         HABITACIÓN
         ========================= -->
    <div class="mb-3">
        <label class="form-label">Habitación</label>

        <select asp-for="HabitacionId"
                class="form-control"
                asp-items="ViewBag.HabitacionId">
        </select>
    </div>

    <!-- =========================
         FECHAS
         ========================= -->
    <div class="row">

        <div class="col-md-6 mb-3">
            <label class="form-label">Fecha Entrada</label>
            <input asp-for="FechaEntrada"
                   type="date"
                   class="form-control" />
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">Fecha Salida</label>
            <input asp-for="FechaSalida"
                   type="date"
                   class="form-control" />
        </div>

    </div>

    <!-- =========================
         BOTÓN
         ========================= -->
    <button type="submit" class="btn btn-success w-100">
        💾 Guardar Reserva
    </button>

</form>

<!-- =========================
     SCRIPT LÓGICO UI
     ========================= -->
<script>
    const radios = document.getElementsByName("tipoCliente");

    const usuarioBox = document.getElementById("usuarioBox");
    const externoBox = document.getElementById("externoBox");

    radios.forEach(r => {
        r.addEventListener("change", function () {

            if (this.value === "usuario") {
                usuarioBox.style.display = "block";
                externoBox.style.display = "none";
            }
            else {
                usuarioBox.style.display = "none";
                externoBox.style.display = "block";
            }

        });
    });
</script>