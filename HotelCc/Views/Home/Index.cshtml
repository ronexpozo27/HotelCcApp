@{
    Layout = "_LayoutPublic";
    ViewData["Title"] = "Hotel CC";
}


<!-- HERO -->

<section class="hero-section">

    <div class="overlay">

        <div class="container text-center text-white">

            <img src="/images/habitaciones/logo.jpg"
                 alt="Hotel CC"
                 style="max-height:140px;
                    filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.5));
                    border-radius: 15px;"
                 class="mb-3" />

            <p class="lead mt-3"
               style="font-family: 'Poppins', sans-serif; font-weight:300; line-height:1.6; letter-spacing:0.4px;">
                Tu comodidad es nuestra prioridad. Disfruta de habitaciones modernas,
                excelente atención y una experiencia inolvidable.
            </p>

            <div class="mt-4">

                <a asp-controller="Habitaciones"
                   asp-action="Catalogo"
                   class="btn btn-warning btn-lg px-4 me-2">

                    Ver Habitaciones

                </a>

            </div>

        </div>

    </div>

</section>

<!-- HABITACIONES DESTACADAS -->

<section class="container py-5">

    <div class="text-center mb-5">

        <h2 class="fw-bold">
            🛏 Habitaciones Destacadas
        </h2>

        <p class="text-muted">
            Descubre nuestras mejores opciones de hospedaje
        </p>

    </div>

    <div class="row g-4">

        <!-- HABITACIÓN 101 -->

        <div class="col-md-4">

            <div class="card border-0 shadow rounded-4 h-100">

                <img src="/images/habitaciones/100.jpg"
                     class="card-img-top"
                     style="height:250px;object-fit:cover;">

                <div class="card-body text-center">

                    <h4 class="fw-bold">
                        Habitación 101
                    </h4>

                    <p class="text-muted">
                        Piso 1 - Estándar
                    </p>

                    <h3 class="text-primary">
                        S/ 100
                    </h3>

                    <a asp-controller="Auth"
                       asp-action="Login"
                       class="btn btn-dark rounded-pill">

                        Reservar

                    </a>

                </div>

            </div>

        </div>

        <!-- HABITACIÓN 201 -->

        <div class="col-md-4">

            <div class="card border-0 shadow rounded-4 h-100">

                <img src="/images/habitaciones/200.jpg"
                     class="card-img-top"
                     style="height:250px;object-fit:cover;">

                <div class="card-body text-center">

                    <h4 class="fw-bold">
                        Habitación 201
                    </h4>

                    <p class="text-muted">
                        Piso 2 - Ejecutiva
                    </p>

                    <h3 class="text-primary">
                        S/ 200
                    </h3>

                    <a asp-controller="Auth"
                       asp-action="Login"
                       class="btn btn-dark rounded-pill">

                        Reservar

                    </a>

                </div>

            </div>

        </div>

        <!-- HABITACIÓN 301 -->

        <div class="col-md-4">

            <div class="card border-0 shadow rounded-4 h-100">

                <img src="/images/habitaciones/300.jpg"
                     class="card-img-top"
                     style="height:250px;object-fit:cover;">

                <div class="card-body text-center">

                    <h4 class="fw-bold">
                        Habitación 301
                    </h4>

                    <p class="text-muted">
                        Piso 3 - Premium
                    </p>

                    <h3 class="text-primary">
                        S/ 350
                    </h3>

                    <a asp-controller="Auth"
                       asp-action="Login"
                       class="btn btn-dark rounded-pill">

                        Reservar

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ESTADÍSTICAS -->

<div class="container py-5">

    <div class="row text-center">

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-body">

                    <h2 class="fw-bold">
                        @ViewBag.TotalHabitaciones
                    </h2>

                    <p class="text-muted mb-0">
                        Habitaciones
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-body">

                    <h2 class="fw-bold">
                        @ViewBag.TotalReservas
                    </h2>

                    <p class="text-muted mb-0">
                        Reservas
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-body">

                    <h2 class="fw-bold">
                        @ViewBag.TotalUsuarios
                    </h2>

                    <p class="text-muted mb-0">
                        Usuarios
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    .hero-section {
        height: 90vh;
        background-image: linear-gradient( rgba(0,0,0,.55), rgba(0,0,0,.55) ), url('/images/habitaciones/homepage.png');
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .overlay {
        width: 100%;
    }
</style>

<!-- FOOTER -->

<footer class="bg-dark text-white mt-5 pt-4 pb-3">

    <div class="container text-center">

        <h5 class="fw-bold mb-3">
            Hotel CC
        </h5>

        <p class="mb-3 text-light">
            Tu comodidad es nuestra prioridad. Experiencia, confort y calidad.
        </p>

        <!-- REDES SOCIALES -->

        <div class="mb-3">

            <a href="#" class="text-white me-3 fs-4">
                <i class="bi bi-facebook"></i>
            </a>

            <a href="#" class="text-white me-3 fs-4">
                <i class="bi bi-instagram"></i>
            </a>

            <a href="#" class="text-white me-3 fs-4">
                <i class="bi bi-whatsapp"></i>
            </a>

            <a href="#" class="text-white fs-4">
                <i class="bi bi-twitter-x"></i>
            </a>

        </div>

        <hr class="border-secondary" />

        <!-- COPYRIGHT -->

        <p class="mb-0 text-secondary small">

            © @DateTime.Now.Year Hotel CC. Todos los derechos reservados.

        </p>

    </div>

</footer>