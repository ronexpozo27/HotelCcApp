@{
    var rol = Context.Session.GetString("Rol");
    var usuario = Context.Session.GetString("Usuario");
    var userId = Context.Session.GetInt32("UserId");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HotelCc</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body>

    <div class="d-flex">

        @if (userId != null)
        {
            <!-- SIDEBAR -->
            <div class="bg-dark text-white p-3" style="width:250px; min-height:100vh;">

            <h4 class="text-center mb-4">
                🏨 HotelCc
            </h4>

            <p class="text-center small text-muted">
                @usuario
            </p>

            <hr class="text-secondary" />

            <ul class="nav flex-column">

                <!-- TODOS -->
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-controller="Habitaciones" asp-action="Index">
                        🛏 Habitaciones
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-controller="Reservas" asp-action="Index">
                        📅 Reservas
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white"
                       asp-controller="Reservas"
                       asp-action="Historial">
                        📚 Historial
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white"
                        asp-controller="Pagos"
                        asp-action="Index">
                        💳 Pagos
                    </a>
                </li>

                <!-- SOLO ADMIN -->
                @if (rol == "Admin")
                {
                    <hr class="text-secondary" />

                    <li class="nav-item mb-2">
                        <span class="text-muted small">ADMIN</span>
                    </li>

                    <li class="nav-item mb-2">
                        <a class="nav-link text-white" asp-controller="Admin" asp-action="Dashboard">
                            📊 Dashboard
                        </a>
                    </li>

                    <li class="nav-item mb-2">
                        <a class="nav-link text-white"
                           asp-controller="Usuarios"
                           asp-action="Index">
                            👥 Usuarios
                        </a>
                    </li>

                }

                <!-- LOGOUT -->
                <hr class="text-secondary" />

                <li class="nav-item mb-2">
                    <a class="nav-link text-danger" asp-controller="Auth" asp-action="Logout">
                        🚪 Salir
                    </a>
                </li>

            </ul>

        </div>
                
        }

    <!-- CONTENT -->
    <div class="flex-grow-1">

            @if (userId != null)
            {
                <div class="d-flex justify-content-end align-items-center px-4 py-3 border-bottom bg-light">

                    <div class="d-flex align-items-center">

                        <div class="rounded-circle bg-primary text-white fw-bold
                            d-flex justify-content-center align-items-center"
                             style="width:40px;height:40px;">

                            @(usuario?.Substring(0, 1).ToUpper())

                        </div>

                        <span class="ms-2 fw-semibold">
                            @usuario
                        </span>

                    </div>

                </div>
            }

        <div class="p-4">

            @RenderBody()

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>