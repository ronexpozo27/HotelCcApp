<table class="table table-hover align-middle">

    <thead class="table-dark">

        <tr>
            <th>Número</th>
            <th>Tipo</th>
            <th>Precio</th>
            <th>Estado</th>
        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>
                    @item.Numero
                </td>

                <td>
                    @item.Tipo
                </td>

                <td>
                    S/ @item.Precio
                </td>

                <td>

                    @if (item.Disponible)
                    {
                        <span class="badge bg-success">
                            Disponible
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Ocupado
                        </span>
                    }

                </td>

            </tr>
        }

    </tbody>

</table>